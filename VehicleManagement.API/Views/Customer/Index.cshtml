@{
    ViewData["Title"] = "Customer Dashboard";
}

<div class="card">
    <div class="card-hd">
        <h1>Customer Dashboard</h1>
        <p>Welcome back.</p>
    </div>
    <div class="card-bd">
        <div class="actions">
            <a class="btn primary" href="#add-vehicle">Add vehicle</a>
        </div>
        <div id="toast" class="toast" role="status" aria-live="polite"></div>
    </div>
</div>

<div style="height:18px"></div>

<div class="card" id="add-vehicle" style="margin-bottom: 18px;">
    <div class="card-hd">
        <h2>Add Vehicle</h2>
        <p>Add a vehicle to your account.</p>
    </div>
    <div class="card-bd">
        <form id="addVehicleForm" class="form">
            <div class="field">
                <label for="vehicleNo">Vehicle No</label>
                <div class="control"><input type="text" id="vehicleNo" required placeholder="BA 12 PA 3456" style="padding-left:12px" /></div>
            </div>
            <div class="field">
                <label for="type">Type</label>
                <div class="control"><input type="text" id="type" placeholder="Bike / Car / SUV" style="padding-left:12px" /></div>
            </div>
            <div class="field">
                <label for="brand">Brand</label>
                <div class="control"><input type="text" id="brand" required placeholder="Toyota" style="padding-left:12px" /></div>
            </div>
            <div class="field">
                <label for="model">Model</label>
                <div class="control"><input type="text" id="model" placeholder="Corolla" style="padding-left:12px" /></div>
            </div>
            <div class="actions" style="grid-column: 1 / -1">
                <button type="submit" class="btn primary">Add Vehicle</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-hd">
        <h2>Vehicles</h2>
        <p>Your registered vehicles.</p>
    </div>
    <div class="card-bd">
        <table class="table" id="vehicleTable">
            <thead>
                <tr>
                    <th>Vehicle No</th>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody id="vehicleList"></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        window.VM.wireNav();

        const token = localStorage.getItem(window.VM.storageKeys.token) || "";
        const role = (window.VM.getUserRole() || "").toLowerCase();
        if (!token) window.location.href = "/login";
        if (role === "staff") window.location.href = "/staff";

        document.addEventListener("DOMContentLoaded", async () => {
            await loadVehicles();

            const addForm = document.getElementById("addVehicleForm");
            addForm.addEventListener("submit", async (e) => {
                e.preventDefault();

                const payload = {
                    vehicleNo: document.getElementById("vehicleNo").value.trim(),
                    brand: document.getElementById("brand").value.trim(),
                    model: (document.getElementById("model").value.trim() || null),
                    type: (document.getElementById("type").value.trim() || null),
                };

                try {
                    await window.VM.apiJson("/api/customer/vehicles", {
                        method: "POST",
                        body: JSON.stringify(payload),
                    });
                    window.VM.showToast("ok", "Vehicle added");
                    addForm.reset();
                    await loadVehicles();
                } catch (err) {
                    window.VM.showToast("bad", err.message || "Failed to add vehicle");
                }
            });
        });

        async function loadVehicles() {
            const list = document.getElementById("vehicleList");
            try {
                const vehicles = await window.VM.apiJson("/api/customer/vehicles");
                if (!vehicles || vehicles.length === 0) {
                    list.innerHTML = '<tr><td colspan="4" class="table-empty">No vehicles found.</td></tr>';
                    return;
                }

                list.innerHTML = vehicles.map(v => `
                    <tr>
                        <td>${v.vehicleNo ?? ""}</td>
                        <td>${v.brand ?? ""}</td>
                        <td>${v.model ?? ""}</td>
                        <td>${v.type ?? ""}</td>
                    </tr>
                `).join("");
            } catch (err) {
                list.innerHTML = '<tr><td colspan="4" class="table-empty">Could not load vehicles.</td></tr>';
            }
        }
    </script>
}
