@{
    ViewData["Title"] = "Customer Dashboard";
    Layout = "_DashboardLayout";
}

<div class="dash-page-header">
    <h1>Vehicle Overview</h1>
    <p>Managing your 2022 Performance Sedan</p>
</div>

<div class="dash-grid">
    <!-- Main Content Column -->
    <div class="dash-main-col">
        <!-- Vehicle Overview Dark Card -->
        <div class="dash-card dash-card-dark vehicle-overview" style="margin-bottom: 24px;">
            <div class="health-score">
                <div class="health-score-inner">
                    <h2>82<span style="font-size: 24px;">%</span></h2>
                    <span>Health Score</span>
                </div>
            </div>
            
            <div class="overview-stats">
                <div class="alert-box">
                    <i data-lucide="triangle-alert" class="alert-icon"></i>
                    <div class="alert-content">
                        <h4>Predictive Failure Alert</h4>
                        <p>Brake Pad failure predicted in 500 miles. Schedule inspection soon.</p>
                    </div>
                </div>
                
                <div class="stats-grid">
                    <div class="stat-item">
                        <p>Tire Pressure</p>
                        <h3>32 PSI</h3>
                        <span class="stat-status status-optimal">Optimal</span>
                    </div>
                    <div class="stat-item">
                        <p>Oil Life</p>
                        <h3>45%</h3>
                        <span class="stat-status status-warning">Monitor</span>
                    </div>
                    <div class="stat-item">
                        <p>Battery</p>
                        <h3>12.6V</h3>
                        <span class="stat-status status-optimal">Strong</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- History Table -->
        <div class="dash-card history-section">
            <div class="history-header">
                <h3>History</h3>
                <div class="history-actions">
                    <button>Filter</button>
                    <button>Export CSV</button>
                </div>
            </div>
            
            <table class="history-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Item/Service</th>
                        <th>Order #</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Invoice</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><div style="color:var(--dash-text);font-weight:500;">Sep 14,</div><div style="color:var(--dash-muted);font-size:12px;">2023</div></td>
                        <td><strong style="color:var(--dash-text);">Premium Synthetic Oil Change</strong></td>
                        <td style="color:var(--dash-muted);">#ORD-90210</td>
                        <td><strong>$124.50</strong></td>
                        <td><span class="status-badge">Completed</span></td>
                        <td><a href="#" class="pdf-link"><i data-lucide="file-text" style="width:14px;height:14px;"></i> PDF</a></td>
                    </tr>
                    <tr>
                        <td><div style="color:var(--dash-text);font-weight:500;">Aug 22,</div><div style="color:var(--dash-muted);font-size:12px;">2023</div></td>
                        <td><strong style="color:var(--dash-text);">Performance Air Filter</strong></td>
                        <td style="color:var(--dash-muted);">#ORD-88742</td>
                        <td><strong>$68.00</strong></td>
                        <td><span class="status-badge" style="color:#059669;background-color:#d1fae5;">Delivered</span></td>
                        <td><a href="#" class="pdf-link"><i data-lucide="file-text" style="width:14px;height:14px;"></i> PDF</a></td>
                    </tr>
                    <tr>
                        <td><div style="color:var(--dash-text);font-weight:500;">Jul 01,</div><div style="color:var(--dash-muted);font-size:12px;">2023</div></td>
                        <td><strong style="color:var(--dash-text);">Brake Fluid Flush</strong></td>
                        <td style="color:var(--dash-muted);">#ORD-86512</td>
                        <td><strong>$210.00</strong></td>
                        <td><span class="status-badge">Completed</span></td>
                        <td><a href="#" class="pdf-link"><i data-lucide="file-text" style="width:14px;height:14px;"></i> PDF</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Sidebar Column -->
    <div class="dash-sidebar-col">
        <!-- Loyalty Progress -->
        <div class="loyalty-progress-container">
            <div class="loyalty-progress-header">
                <span>LOYALTY PROGRESS</span>
                <span>$3,240 / $5,000</span>
            </div>
            <div class="progress-bar-bg">
                <div class="progress-bar-fill"></div>
            </div>
            <p>Spend another $1,760 to unlock your 10% Gold Discount.</p>
        </div>

        <!-- Upcoming -->
        <div class="widget">
            <div class="widget-title">
                <h3>Upcoming</h3>
                <i data-lucide="calendar" style="color:var(--dash-muted);"></i>
            </div>
            
            <div class="appointment-item">
                <div class="date-badge">
                    <span class="date-month">Oct</span>
                    <span class="date-day">12</span>
                </div>
                <div class="appointment-details">
                    <h4>Annual Maintenance</h4>
                    <p>09:30 AM • Downtown Service Center</p>
                </div>
            </div>
            
            <div class="appointment-item">
                <div class="date-badge muted">
                    <span class="date-month">Nov</span>
                    <span class="date-day">05</span>
                </div>
                <div class="appointment-details">
                    <h4 style="color:var(--dash-muted);">Tire Rotation</h4>
                    <p>To be scheduled</p>
                </div>
            </div>
            
            <button class="btn-dark">Book New Appointment</button>
        </div>

        <!-- Special Request -->
        <div class="widget special-request">
            <div class="widget-title">
                <h3>Special Request</h3>
            </div>
            <p>Can't find a specific OEM part? Our procurement team can source rare and vintage components for you.</p>
            
            <div class="request-card">
                <div class="request-icon">
                    <i data-lucide="package" style="color:var(--dash-muted);"></i>
                </div>
                <div class="request-details">
                    <h4>M-Series Carbon Spoiler</h4>
                    <p>Requested 2 days ago</p>
                </div>
                <span class="status-searching">SEARCHING</span>
            </div>
            
            <button class="btn-outline">
                <i data-lucide="plus-circle" style="width:16px;"></i>
                New Part Request
            </button>
        </div>

        <!-- Vehicle Match -->
        <div class="vehicle-match-card">
            <img src="https://images.unsplash.com/photo-1617531653332-bd46c24f2068?q=80&w=2115&auto=format&fit=crop" alt="Performance Sedan Engine" />
            <div class="vehicle-match-overlay">
                <span>VEHICLE MATCH</span>
                <h3>2022 Performance Sedan</h3>
                <p>Full OEM Part Compatibility Verified</p>
            </div>
        </div>
    </div>
</div>
