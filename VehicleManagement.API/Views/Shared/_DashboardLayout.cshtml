@using Microsoft.AspNetCore.Identity
@using Vehicle.Domain.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    
    // For demonstration: If no user is authenticated, fetch the first user from the DB
    // Preferring a 'Customer' role for the Customer Dashboard context.
    if (currentUser == null)
    {
        currentUser = UserManager.Users.FirstOrDefault(u => u.UserRole == "Customer") 
                      ?? UserManager.Users.FirstOrDefault();
    }
    
    var fullName = currentUser?.FullName ?? "Sarah Jenkins (Demo)";
    var userRole = currentUser?.UserRole ?? "Premium Member";
    var initials = string.Join("", fullName.Split(' ').Select(n => (n.Length > 0 ? n[0].ToString() : "")));
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] • Vehicle Management Dashboard</title>
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="dash-sidebar">
        <div class="dash-brand">
            <i data-lucide="car"></i>
            <span>VehicleMgmt</span>
        </div>


        <nav class="dash-nav">
            <a href="/Customer/Dashboard" class="dash-nav-item @(string.Equals((string)ViewContext.RouteData.Values["Action"], "Dashboard", StringComparison.OrdinalIgnoreCase) || string.Equals((string)ViewContext.RouteData.Values["Action"], "Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                <i data-lucide="layout-dashboard"></i>
                Dashboard
            </a>
            <a href="/Customer/Settings" class="dash-nav-item @(string.Equals((string)ViewContext.RouteData.Values["Action"], "Settings", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                <i data-lucide="settings"></i>
                Settings
            </a>
            <a href="/" class="dash-nav-item">
                <i data-lucide="home"></i>
                Back to Site
            </a>
        </nav>

        <div class="dash-sidebar-footer" style="padding: 1.5rem; border-top: 1px solid var(--dash-border); margin-top: auto;">
            <div class="dash-user-footer" style="display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--dash-primary-light); color: var(--dash-primary); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;">
                    @initials
                </div>
                <div style="overflow: hidden;">
                    <h4 style="margin: 0; font-size: 0.875rem; font-weight: 600; color: var(--dash-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@fullName</h4>
                    <p style="margin: 0; font-size: 0.75rem; color: var(--dash-muted);">@userRole</p>
                </div>
            </div>
            <button class="dash-btn-primary">
                <i data-lucide="log-out"></i>
                Log Out
            </button>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="dash-main">
        <!-- Header -->
        <header class="dash-header">
            <div class="dash-search">
                <i data-lucide="search" style="color:var(--dash-muted);width:16px;"></i>
                <input type="text" placeholder="Search vehicles, services, orders..." />
            </div>
            
            <div class="dash-header-actions">
                <div class="dash-loyalty">
                    <i data-lucide="award" style="width:16px;"></i>
                    Gold Tier
                </div>
                
                <button class="dash-icon-btn" aria-label="Notifications">
                    <i data-lucide="bell"></i>
                </button>
                <button class="dash-icon-btn" aria-label="Messages">
                    <i data-lucide="message-square"></i>
                </button>
                
                <a href="/Customer/Profile">
                    <img src="https://ui-avatars.com/api/?name=@(fullName.Replace(" ", "+"))&background=f97316&color=fff&rounded=true" alt="User Avatar" style="width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: block;" />
                </a>
            </div>
        </header>

        <!-- Dynamic Content -->
        <main class="dash-content">
            @RenderBody()
        </main>
    </div>

    <!-- Initialize Lucide Icons -->
    <script>
        lucide.createIcons();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
